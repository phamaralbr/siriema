---
import { SITE, whatsappLink } from '../config/site';
import { withBase } from '../lib/url';
---

<header class="sticky top-0 z-40 border-b border-sand/70 bg-parchment/90 backdrop-blur">
  <div class="mx-auto flex max-w-content items-center justify-between px-5 py-4 sm:px-8">
    <a href={withBase('/')} class="flex items-center gap-2">
      {SITE.logo ? (
        <img src={withBase(SITE.logo)} alt={SITE.logoAlt} class="h-12 w-auto sm:h-14" />
      ) : (
        <span class="font-display text-xl font-semibold tracking-tight text-ink">
          {SITE.name}
        </span>
      )}
    </a>

    <nav class="hidden items-center gap-8 sm:flex">
      <a href={`${withBase('/')}#expedicoes`} class="font-body text-sm text-stone transition-colors hover:text-ink">
        Expedições
      </a>
      <a href={`${withBase('/')}#sobre`} class="font-body text-sm text-stone transition-colors hover:text-ink">
        Como funciona
      </a>
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-whatsapp !px-5 !py-2 text-sm"
      >
        Falar no WhatsApp
      </a>
    </nav>

    <a
      href={whatsappLink()}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-whatsapp !px-4 !py-2 text-sm sm:hidden"
      aria-label="Falar no WhatsApp"
    >
      WhatsApp
    </a>
  </div>
</header>

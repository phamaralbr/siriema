---
import type { CollectionEntry } from 'astro:content';
import { whatsappLink } from '../config/site';
import { formatDateRangeShort } from '../lib/dates';
import { withBase } from '../lib/url';

interface Props {
  expedition: CollectionEntry<'expeditions'>;
}
const { expedition } = Astro.props;
const e = expedition.data;

const difficultyColor: Record<string, string> = {
  Leve: 'bg-moss/15 text-moss',
  Moderada: 'bg-rust/15 text-rust-dark',
  Intensa: 'bg-ink/10 text-ink',
};

const priceFormatted = new Intl.NumberFormat('pt-BR', {
  style: 'currency',
  currency: 'BRL',
  maximumFractionDigits: 0,
}).format(e.priceFrom);

const detailHref = withBase(`/expedicoes/${expedition.slug}/`);
const coverSrc = withBase(e.cover);

const cardWhatsapp = whatsappLink(
  e.whatsappMessage ?? `Olá! Tenho interesse na expedição "${e.title}". Pode me passar mais detalhes?`
);
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-sand bg-white/60 shadow-sm transition-shadow hover:shadow-md">
  <a href={detailHref} class="block overflow-hidden">
    <div class="relative aspect-[4/3] overflow-hidden bg-sand">
      <img
        src={coverSrc}
        alt={e.title}
        loading="lazy"
        class={`h-full w-full object-cover transition-transform duration-500 ${
          e.esgotado ? 'grayscale' : 'group-hover:scale-105'
        }`}
      />
      {e.esgotado && (
        <div class="absolute inset-0 flex items-center justify-center bg-ink/35">
          <span class="rounded-full bg-ink px-4 py-1.5 font-mono text-xs font-semibold uppercase tracking-wider text-parchment">
            Esgotado
          </span>
        </div>
      )}
      {e.featured && !e.esgotado && (
        <span class="absolute left-3 top-3 rounded-full bg-rust px-3 py-1 font-mono text-[11px] uppercase tracking-wide text-parchment">
          Destaque
        </span>
      )}
      <div class="absolute bottom-3 left-3 flex items-center gap-1.5 rounded-lg bg-ink/80 px-3 py-1.5 font-mono text-xs font-semibold tracking-wide text-parchment shadow-sm backdrop-blur-sm">
        <svg viewBox="0 0 20 20" fill="none" class="h-3.5 w-3.5 flex-shrink-0" aria-hidden="true">
          <rect x="2.5" y="4" width="15" height="13" rx="2" stroke="currentColor" stroke-width="1.4" />
          <path d="M2.5 8h15M6.5 2v4M13.5 2v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
        {formatDateRangeShort(e.date, e.endDate)}
      </div>
    </div>
  </a>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center justify-between gap-2">
      <span class="font-mono text-xs uppercase tracking-wide text-stone">{e.location}</span>
      {e.difficulty && (
        <span class={`rounded-full px-2.5 py-0.5 font-mono text-[11px] ${difficultyColor[e.difficulty]}`}>
          {e.difficulty}
        </span>
      )}
    </div>

    <h3 class="mt-2 font-display text-xl font-semibold leading-snug text-ink">
      <a href={detailHref} class="hover:underline decoration-rust decoration-2 underline-offset-2">
        {e.title}
      </a>
    </h3>
    <p class="mt-1 text-sm text-stone">{e.subtitle}</p>

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1.5 font-mono text-xs text-stone">
      <span>{e.durationDays} {e.durationDays === 1 ? 'dia' : 'dias'}</span>
      {e.groupSize && <span>· {e.groupSize}</span>}
    </div>

    <div class="mt-5 flex items-center justify-between border-t border-sand pt-4">
      <div>
        <p class="font-mono text-[11px] uppercase tracking-wide text-stone">a partir de</p>
        <p class="font-display text-lg font-semibold text-ink">{priceFormatted}</p>
      </div>
      {e.esgotado ? (
        <span class="rounded-full bg-stone/15 px-4 py-2 font-mono text-xs uppercase tracking-wide text-stone">
          Esgotado
        </span>
      ) : (
        <a
          href={cardWhatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp !px-4 !py-2 text-sm"
        >
          Reservar
        </a>
      )}
    </div>
  </div>
</article>
